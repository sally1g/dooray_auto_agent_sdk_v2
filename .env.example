# Anthropic (SDK 방식 — API Key 필수)
# console.anthropic.com에서 발급. v2는 SDK를 직접 쓰므로 OAuth는 동작하지 않음
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Dooray
DOORAY_API_TOKEN=xxxxxxxx
DOORAY_TENANT_DOMAIN=your-org.dooray.com
DOORAY_PROJECT_ID=1234567890

# Target Repository
TARGET_REPO_PATH=./target_repo
TARGET_REPO_URL=https://github.com/your-org/your-nextjs-app.git
TARGET_BETA_BRANCH=beta

# 워크플로우 상태 전이(할일→처리중→구현/처리실패, 완료 시 브랜치 삭제) 자동 관리
# false로 두면 상태는 건드리지 않고 댓글만 작성
MANAGE_WORKFLOW_STATE=true

# GitHub (HTTPS push용)
# SSH 방식이면 비워두고 SSH 키로 관리
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USER=your-github-username

# Anthropic SDK / 에이전트 루프
# 모델: claude-sonnet-4-5 / claude-opus-4-5 / claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_MAX_TOKENS=8192
CLAUDE_MAX_TURNS=50
CLAUDE_TIMEOUT_SEC=600
BASH_TIMEOUT_SEC=300

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# Webhook Security
# ?key=<secret> 쿼리 파라미터 검증 (빈 값이면 검증 스킵)
WEBHOOK_SECRET=
